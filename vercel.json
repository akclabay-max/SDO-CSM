{
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static-build",
      "config": {
        "buildCommand": "flutter build web",
        "outputDirectory": "build/web",
        "installCommand": "flutter pub get"
      }
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}